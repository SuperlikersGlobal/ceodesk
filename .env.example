# CeoDesk — variables de entorno (configúralas en Netlify → Site settings → Environment).
# Para desarrollo local: copia a .env y completa (netlify dev las carga).

# ── Login con Google (reutiliza el Client ID de tus otros proyectos) ─────────
GOOGLE_CLIENT_ID=
# Dominio de correo permitido para entrar.
ALLOWED_DOMAIN=iwin.im

# ── Sesión ──────────────────────────────────────────────────────────────────
# Secreto para firmar los tokens de sesión (cadena larga y aleatoria).
AUTH_SECRET=

# ── Roles y organigrama ─────────────────────────────────────────────────────
# Correos con rol de CEO (ven todo). Separados por coma.
CEO_EMAILS=luis@iwin.im
# Chief of Staff: ve todo lo asignado al CEO. Separados por coma.
CHIEF_OF_STAFF=tatiana@iwin.im
# Organigrama: JSON { "correo": { "n": "Nombre", "l": "correo_del_jefe" } }.
# La raíz (CEO) tiene "l": null. CONTIENE PII: solo aquí, nunca en el repo.
ORG={}
# Delegaciones extra de visibilidad: JSON { "delegado": ["correo1","correo2"] }
VIEWER_DELEGATIONS={}
# Cargos opcionales por correo, JSON. Ej: {"ana@iwin.im":"Líder de Producto"}
USER_TITLES={}

# ── Áreas / Proyectos (para clasificar ítems) ───────────────────────────────
# Lista separada por coma.
AREAS=Producto,Desarrollo,Micrositio,UX,Diseño,Contenidos,Creatividad,Engagement,Ecosistemas,BI,Comercial,Administración & Finanzas,Legal,People,Gerencia
