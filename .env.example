# CeoDesk — variables de entorno (configúralas en Netlify → Site settings → Environment).
# Para desarrollo local: copia a .env y completa (netlify dev las carga).

# ── Login con Google (reutiliza el Client ID de tus otros proyectos) ─────────
GOOGLE_CLIENT_ID=
# Dominio de correo permitido para entrar.
ALLOWED_DOMAIN=iwin.im

# ── Sesión ──────────────────────────────────────────────────────────────────
# Secreto para firmar los tokens de sesión (cadena larga y aleatoria).
AUTH_SECRET=

# ── Roles y organigrama ─────────────────────────────────────────────────────
# Correos con rol de CEO (ven todo). Separados por coma.
CEO_EMAILS=luis@iwin.im
# Chief of Staff: ve todo lo asignado al CEO. Separados por coma.
CHIEF_OF_STAFF=tatiana@iwin.im
# Organigrama: JSON { "correo": { "n": "Nombre", "l": "correo_del_jefe" } }.
# La raíz (CEO) tiene "l": null. CONTIENE PII: solo aquí, nunca en el repo.
ORG={}
# Delegaciones extra de visibilidad: JSON { "delegado": ["correo1","correo2"] }
VIEWER_DELEGATIONS={}
# Cargos opcionales por correo, JSON. Ej: {"ana@iwin.im":"Líder de Producto"}
USER_TITLES={}

# ── Áreas / Proyectos (para clasificar ítems) ───────────────────────────────
# Lista separada por coma.
AREAS=Producto,Desarrollo,Micrositio,UX,Diseño,Contenidos,Creatividad,Engagement,Ecosistemas,BI,Comercial,Administración & Finanzas,Legal,People,Gerencia

# ── Google Tasks (hub compartido con LADCC — solo el CEO) ────────────────────
# Cuenta de servicio con delegación de dominio (Workspace). Se puede REUTILIZAR
# la misma del CRM (sl-crm-live), pues el scope tasks ya está autorizado.
# Correo de la cuenta de servicio (…@…iam.gserviceaccount.com).
GOOGLE_SA_CLIENT_EMAIL=
# Clave privada de la cuenta de servicio (con "\n" escapados). SECRETO.
GOOGLE_SA_PRIVATE_KEY=
# Cuenta de Workspace a impersonar (dueña del hub de Google Tasks).
GOOGLE_TASKS_IMPERSONATE=luis@iwin.im

# ── Jira (OAuth 2.0 3LO — cada quien conecta su propio Jira) ─────────────────
# App OAuth registrada en developer.atlassian.com. Callback:
#   https://ceodesk.superlikers.com/api/jira-callback
JIRA_OAUTH_CLIENT_ID=
# Secreto de la app OAuth. SECRETO.
JIRA_OAUTH_CLIENT_SECRET=
# Base pública de la app (para el redirect_uri). Por defecto la de producción.
APP_BASE_URL=https://ceodesk.superlikers.com

# ── Notificaciones por correo (SMTP, Google Workspace) ──────────────────────
# Se puede reutilizar la misma cuenta/app password del CRM.
SMTP_USER=luis@iwin.im
# App password de Gmail (16 caracteres; se pega con espacios, se limpian solos). SECRETO.
SMTP_PASS=
# Remitente mostrado. Por defecto: "CeoDesk <SMTP_USER>".
SMTP_FROM=CeoDesk <luis@iwin.im>
# (Opcional) host/puerto SMTP. Por defecto smtp.gmail.com:465 (TLS).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
